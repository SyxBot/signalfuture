# === ZookAgent Configuration ===

# Server
PORT=3000

# Storage
SQLITE_PATH=./data/signals.db

# Detection thresholds
SPIKE_THRESHOLD=3.0       # Volume must be >= X * rolling average to trigger
SCORE_THRESHOLD=2.0       # Minimum signal score to store/broadcast

# Rolling window for average volume (number of 1m candles)
VOLUME_WINDOW=20

# Cooldown per symbol in milliseconds (prevents signal spam)
COOLDOWN_MS=120000

# Symbols to track (comma-separated Binance USDT futures symbols)
# Leave blank to use the default list of 20 high-liquidity symbols
# SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Telegram Alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_SCORE=5.0

# Logging: debug | info | warn | error
LOG_LEVEL=info
